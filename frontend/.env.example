# Copy this file to frontend/.env for local dev. Do NOT set REACT_APP_DEV_AUTH
# in any production build (see warning below) — these are all optional.

# ── Backend API base URL — REQUIRED when frontend and backend are deployed
# as separate services (e.g. two Railway services, not one unified deploy) ──
# Every axios call in this app uses a relative path like '/api/admin/users',
# which only reaches a real backend when both are served from the same
# origin. Set this to the backend service's public URL so those calls target
# it instead of the frontend's own origin (where there is no API — calls
# would otherwise 404 or, worse, silently hit the SPA's own catch-all and
# get back HTML instead of JSON). Build-time variable — bakes into the
# compiled JS at `npm run build`, so it must be set in the frontend
# service's env BEFORE building, not just added and left for a live app to
# pick up. Leave unset for local dev (CRA's `proxy` field in package.json
# already forwards /api/* to localhost:8001) or a future unified deploy.
# REACT_APP_API_URL=https://your-backend-service.up.railway.app

# ── DEV-ONLY auth bypass — DANGER in production ─────────────────────────────
# When 'true', AuthContext.jsx auto-logs-in without a real session whenever
# the backend /me call fails. This is a React build-time variable — it gets
# baked into the compiled JS at `npm run build`, so it CANNOT be toggled at
# runtime via Railway's dashboard the way backend env vars can. Leave this
# UNSET (or 'false') for any build that will be deployed, even if the backend
# has REQUIRE_AUTH=true — a leftover 'true' here bypasses the RBAC hard-block
# entirely on the frontend regardless of backend enforcement.
# REACT_APP_DEV_AUTH=false

# ── Optional: Alpha Vantage key for the quantitative-nlp-research demo tab ──
# Only used by one module's "live data bus" example snippet. Same build-time
# caveat as above — bakes into the client bundle, so don't use a sensitive key.
# REACT_APP_AV_KEY=

# Supabase team database (module registry, access flags, usage telemetry).
# OPTIONAL — working defaults for the team "New App" project are baked into
# src/services/supabaseClient.js. Set these only to point at a different
# project or after rotating the publishable key.
#
# In Vercel: Project → Settings → Environment Variables (then redeploy).
# Locally:   copy to frontend/.env
#
# The anon/publishable key is safe to expose in the browser — platform_* tables
# are protected by RLS (read-only + usage-event insert for this key).
REACT_APP_SUPABASE_URL=https://ynxmxgjdivriakhxxptk.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_kXTDciFVU_rhl3gX-zjcKA__Vjs-IW5
