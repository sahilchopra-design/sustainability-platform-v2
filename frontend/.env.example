# Copy this file to frontend/.env for local dev. Do NOT set REACT_APP_DEV_AUTH
# in any production build (see warning below) — these are all optional.

# ── DEV-ONLY auth bypass — DANGER in production ─────────────────────────────
# When 'true', AuthContext.jsx auto-logs-in without a real session whenever
# the backend /me call fails. This is a React build-time variable — it gets
# baked into the compiled JS at `npm run build`, so it CANNOT be toggled at
# runtime via Railway's dashboard the way backend env vars can. Leave this
# UNSET (or 'false') for any build that will be deployed, even if the backend
# has REQUIRE_AUTH=true — a leftover 'true' here bypasses the RBAC hard-block
# entirely on the frontend regardless of backend enforcement.
# REACT_APP_DEV_AUTH=false

# ── Optional: Alpha Vantage key for the quantitative-nlp-research demo tab ──
# Only used by one module's "live data bus" example snippet. Same build-time
# caveat as above — bakes into the client bundle, so don't use a sensitive key.
# REACT_APP_AV_KEY=
