      "findings": [
        {
          "severity": "PASS",
          "line_approx": 19,
          "issue": "PRNG implementation — canonical sr() formula present",
          "detail": "sr = (s) => { let x = Math.sin(s+1)*10000; return x - Math.floor(x); } matches spec exactly. No Math.random() in executable code."
        },
        {
          "severity": "PASS",
          "line_approx": 78,
          "issue": "WACC_adj formula — correct",
          "detail": "waccAdjusted = asset.wacc_base + asset.beta_c * carbonPrice(scenario, 5) matches WACC_base + β_carbon × P_carbon(t=5). No sign errors."
        },
        {
          "severity": "P1",
          "line_approx": 61,
          "issue": "DCF engine missing terminal value — spec-required TV + spread guard absent",
          "detail": "computeDcfImpairment sums only explicit annual CFs over horizonYears with no terminal value. The spec requires TV with guard (discount_rate - growth_rate) > 0.005 minimum spread to prevent implosion. TV is entirely absent; NPV is materially understated and the spread-guard cannot fire.",
          "fix": "After summing annual CFs: const spreadMin = 0.005; const g_terminal = 0.01; const spreadBase = Math.max(spreadMin, asset.wacc_base - g_terminal); const spreadAdj = Math.max(spreadMin, waccAdjusted - g_terminal); const lastCFBase = adjustedCFs[adjustedCFs.length-1].base_cf; const lastCFAdj = adjustedCFs[adjustedCFs.length-1].adjusted_cf; const tvBase = (lastCFBase * (1+g_terminal)) / spreadBase / Math.pow(1+asset.wacc_base, horizonYears); const tvAdj = (lastCFAdj * (1+g_terminal)) / spreadAdj / Math.pow(1+waccAdjusted, horizonYears); npvBase += tvBase; npvAdj += tvAdj;"
        },
        {
          "severity": "P2",
          "line_approx": 65,
          "issue": "Hardcoded magic numbers — revenue yield 0.18 and decline rate 0.98",
          "detail": "baseRevenue = asset.book * 0.18 * Math.pow(0.98, i). The 18% yield and 2%/yr revenue decline are unexplained magic numbers not tied to any documented assumption.",
          "fix": "Extract as named constants: const BASE_REVENUE_YIELD = 0.18; const ANNUAL_REVENUE_DECLINE_RATE = 0.98; or add as per-asset properties."
        },
        {
          "severity": "PASS",
          "line_approx": 125,
          "issue": "Division guard on scenarioCompare — totalBook || 1 present",
          "detail": "pct = (total / (totalBook || 1)) * 100. Guard in place. PASS."
        }
      ]
