      "source": "NGFS Phase 5, IIASA Scenario Explorer"
    },
    {
      "id": "delayed_transition",
      "name": "Delayed Transition",
      "category": "Disorderly",
      "warming_2100_c": 1.7,
      "narrative": "Annual emissions do not decrease until 2030; strong policy is then needed to limit warming below 2°C, producing a sharp, disorderly repricing.",
      "source": "NGFS Phase 5, IIASA Scenario Explorer"
    },
    {
      "id": "fragmented_world",
      "name": "Fragmented World",
      "category": "Too little, too late",
      "warming_2100_c": 2.3,
      "narrative": "Delayed and divergent policy across countries; only some regions (e.g. the EU) pursue ambitious targets, combining elevated transition AND physical risk.",
      "source": "NGFS Phase 5, IIASA Scenario Explorer"
    },
    {
      "id": "ndcs",
      "name": "NDCs",
      "category": "Hot house world",
      "warming_2100_c": 2.4,
      "narrative": "All pledged Nationally Determined Contributions are implemented, but nothing beyond; moderate emission declines with high residual physical risk.",
      "source": "NGFS Phase 5, IIASA Scenario Explorer"
    },
    {
      "id": "current_policies",
      "name": "Current Policies",
      "category": "Hot house world",
      "warming_2100_c": 2.9,
      "narrative": "Only policies already implemented are preserved; emissions stay near today's level and physical risks dominate. Serves as the stress baseline.",
      "source": "NGFS Phase 5, IIASA Scenario Explorer"
    }
  ],
