# Copy this file to backend/.env and fill in real values.
# NEVER commit backend/.env — it's already gitignored.

# ── Database — Supabase Postgres ─────────────────────────────────────────────
# Session pooler connection string. Get this from your Supabase project:
# Project Settings → Database → Connection string → URI (session mode, port 5432)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── App / API settings ────────────────────────────────────────────────────────
# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Use a DIFFERENT value in production than in local dev.
SECRET_KEY=generate-a-strong-random-key-here

# development | production
ENVIRONMENT=development

# Set to true in production (and whenever you want the RBAC module-level
# access controls to actually be enforced, including the invite/preset
# system). Only false for quick local dev without logging in.
REQUIRE_AUTH=false

# Comma-separated allowed origins for CORS. In production, set this to your
# deployed domain (e.g. https://your-app.up.railway.app) — same-origin
# deployments (frontend served by the backend, see docs/DEPLOYMENT.md) still
# need this set correctly for any cross-origin API callers.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4000,http://127.0.0.1:4000

# ── Optional live financial-data integrations (leave unset to skip) ─────────
# EODHD Financial Data API (All-In-One tier) — eodhd.com
# EODHD_API_KEY=

# Alpha Vantage API (India NSE/BSE + Forex) — alphavantage.co
# ALPHA_VANTAGE_API_KEY=

# yfinance — India NSE/BSE fundamentals (free, no API key needed)
YFINANCE_ENABLED=true

# Finnhub API — Refinitiv ESG scores (free tier: 60 req/min) — finnhub.io
# FINNHUB_API_KEY=

# EIA Open Data v2 — US grid mix + Henry Hub gas price (free, instant signup,
# no approval wait) — eia.gov/opendata/register.php
# EIA_API_KEY=

# ENTSO-E Transparency Platform — EU day-ahead prices + generation mix (free,
# registered security token, no payment) — transparency.entsoe.eu ->
# My Account Settings -> Web API Security Token
# ENTSOE_API_TOKEN=

# UCDP (Uppsala Conflict Data Program) — conflict-event nowcasting (free, but
# NOT self-service: email mertcan.yilmaz@pcr.uu.se with name/affiliation/role/
# project description; manual review, ~3-5 business days) — ucdp.uu.se/apidocs/
# Without this, /api/v1/ucdp falls back to a labeled seeded sample.
# UCDP_API_TOKEN=

# UK EPC Register — address-level building energy performance certificates
# (free, but auth changed to GOV.UK One Login bearer token issued only via the
# web portal — no headless signup) — get-energy-performance-data.communities.gov.uk
# Without this, /api/v1/uk-epc falls back to a labeled seeded sample.
# EPC_API_BEARER_TOKEN=

# Open-Meteo — weather + CMIP6 climate projections (free tier is keyless but
# non-commercial only; $29/mo Standard unlocks commercial Forecast API only;
# $99/mo Professional needed for commercial Historical Weather/Climate/Ensemble)
# — open-meteo.com/en/pricing
# OPEN_METEO_API_KEY=

# OpenFIGI — ISIN/CUSIP/ticker -> FIGI + issuer identification (free without a
# key at a low rate limit: 10 mappings/batch, 25 req/60s; a free key raises
# limits) — openfigi.com/api
# OPENFIGI_API_KEY=

# ── Invite email sending (pick ONE option, both optional) ───────────────────
# Platform URL used in invite links. Set to your deployed domain in production.
PLATFORM_BASE_URL=http://localhost:3000

# OPTION A — SendGrid (recommended, free tier = 100 emails/day)
# Sign up at sendgrid.com → Settings → API Keys → Create API Key (Mail Send permission)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTION B — Gmail SMTP (no new account needed, works locally)
# 1. Google Account → Security → 2-Step Verification → App Passwords → Generate
# 2. Use the 16-character App Password below (NOT your Gmail password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-gmail@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# INVITE_FROM_EMAIL=noreply@yourcompany.com
# INVITE_FROM_NAME=Your Platform Name
